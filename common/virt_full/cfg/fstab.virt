# fstab file.
#<src>		<mnt_point>	<type>	<mnt_flags and options>                              <fs_mgr_flags>
/dev/block/vde	/usr		ext4	ro,barrier=1  wait,required
/dev/block/vdd	/vendor		ext4	ro,barrier=1  wait,required
/dev/block/vdc	/sys_prod	ext4	ro,barrier=1  wait
/dev/block/vdb	/chip_prod	ext4	ro,barrier=1  wait
/dev/block/vda	/data		ext4	nosuid,nodev,noatime,barrier=1,data=ordered,noauto_da_alloc wait,reservedsize=104857600
/dev/block/by-name/misc			/misc	none	none	wait
